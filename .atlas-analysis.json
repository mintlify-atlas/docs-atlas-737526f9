  "keyFeatures": [
    "Knowledge Graph Extraction - Extract entities, relationships, and claims from unstructured text using LLMs",
    "Hierarchical Community Detection - Leiden algorithm for multi-level graph clustering and community summaries",
    "Global Search - Map-reduce search across AI-generated community reports for holistic dataset understanding",
    "Local Search - Entity-focused search combining knowledge graph with raw text chunks",
    "DRIFT Search - Enhanced local search with community context for comprehensive retrieval",
    "Automated Prompt Tuning - Generate domain-specific prompts optimized for your data",
    "Flexible Configuration - YAML-based configuration with support for multiple LLM providers",
    "CLI and Python API - Command-line tools and programmatic access for all operations",
    "Vector Embeddings - Text embedding support with multiple vector store backends",
    "Incremental Updates - Update existing indexes with new data efficiently"
  ],
  "publicApiSurface": [
    "build_index() - Build a knowledge graph index from source documents",
    "global_search() - Perform global search across community summaries",
    "global_search_streaming() - Stream global search results",
    "local_search() - Perform entity-focused local search",
    "local_search_streaming() - Stream local search results",
    "drift_search() - Perform DRIFT search with community context",
    "drift_search_streaming() - Stream DRIFT search results",
    "basic_search() - Perform basic vector similarity search",
    "basic_search_streaming() - Stream basic search results",
    "generate_indexing_prompts() - Generate optimized prompts for indexing",
    "graphrag init - Initialize a new GraphRAG project",
    "graphrag index - Build knowledge graph index",
    "graphrag update - Update existing index with new data",
    "graphrag query - Query the knowledge graph",
    "graphrag prompt-tune - Auto-generate optimized prompts"
  ]
}
